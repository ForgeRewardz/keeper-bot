# =============================================================================
# mvp-keeper-bot — environment variables
# =============================================================================
# Canonical names; see mobileSpecs/.env.shared.example for the shared source.
# Generate this file automatically via: ../scripts/env-template.sh
# =============================================================================

# --- Required ----------------------------------------------------------------
# PostgreSQL connection string.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/rewardz

# Filesystem path to admin keypair JSON (for signing on-chain txs).
# For Railway deployment, see KEYPAIR_BASE64 strategy in HOSTING.md.
KEYPAIR=/path/to/admin-keypair.json

# Deployed REWARDZ program pubkey.
PROGRAM_ID=mineHEHyaVbQAkcPDDCuCSbkfGNid1RVz6GzcEgSVTh

# Cross-service shared secret. MUST match api/.env value exactly.
INTERNAL_API_KEY=replace-me-with-random-64-char-secret

# --- Optional (with defaults) ------------------------------------------------
# Solana RPC endpoint.
SOLANA_RPC_URL=http://127.0.0.1:8899

# HTTP listen address for serve-api mode.
API_LISTEN_ADDR=0.0.0.0:8081

# REWARDZ api base URL (for receipt-signing callbacks).
API_BASE_URL=http://127.0.0.1:3001

# Cron intervals (seconds). Shorten for rehearsals; see README for production cadence.
POINT_ROOT_INTERVAL_SECS=28800
RENTAL_SETTLE_INTERVAL_SECS=604800
SUBSCRIPTION_POLL_INTERVAL_SECS=60
GAME_LOOP_INTERVAL_SECS=15
CAPACITY_RESET_INTERVAL_SECS=3600
QUALITY_SCORE_INTERVAL_SECS=3600
MILESTONE_PROCESSOR_INTERVAL_SECS=300
ANTI_ABUSE_INTERVAL_SECS=3600
VISIBILITY_TICK_INTERVAL_SECS=900
LEADERBOARD_INTERVAL_SECS=86400
STAKE_WATCHER_INTERVAL_SECS=60
REWARDZ_PUBLISH_INTERVAL_SECS=3600

# Receipt-signing TTLs (seconds).
POINTS_REQUEST_TTL_SECONDS=300
POINTS_RECEIPT_TTL_SECONDS=600

# CORS origins for /sign-receipt endpoint.
POINTS_CORS_ORIGINS=*
